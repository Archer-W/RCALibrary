# RCALibrary configuration. Copy to `.env` and adjust. All vars are prefixed RCA_.
# Nothing here is required to run the sample-data MVP — these are the defaults.

# Active data source: "sample" (CSV files, offline) or "snowflake" (Phase 2).
RCA_DATASOURCE=sample

# Paths (defaults resolve relative to the repo root).
# RCA_TEMPLATES_DIR=./templates
# RCA_SAMPLES_DIR=./data/samples
# RCA_FRONTEND_DIR=./frontend

# Usage logging placeholder: "noop" (default) or "file" (append JSONL).
RCA_AUDIT_MODE=noop
# RCA_AUDIT_FILE=./audit.jsonl

# Server.
RCA_HOST=0.0.0.0
RCA_PORT=8000
RCA_CORS_ORIGINS=*

# --- Snowflake (Phase 2 — not used yet; documented here for later) ---
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=
# SNOWFLAKE_ROLE=
